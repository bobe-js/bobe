{
  "name": "bobe-router",
  "version": "0.0.65",
  "main": "dist/bobe-router.cjs.js",
  "module": "dist/bobe-router.esm.js",
  "browser": "dist/bobe-router.umd.js",
  "types": "dist/index.d.ts",
  "private": false,
  "dependencies": {
    "aoye": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bobe-router.esm.js",
      "require": "./dist/bobe-router.cjs.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.esm.js",
      "require": "./dist/plugin.cjs.js"
    }
  },
  "devDependencies": {},
  "scripts": {
    "build": "rm -rf ./dist && rollup -c",
    "dev": "rollup -c -w",
    "tw": "vitest"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "keywords": [
    "bobe-router",
    "smooth",
    "cat"
  ],
  "author": "smooth-cat",
  "repository": {
    "type": "git",
    "url": "git+git@github.com:bobe-js/bobe.git"
  },
  "bugs": {
    "url": "https://github.com/bobe-js/bobe/issues"
  },
  "homepage": "https://github.com/bobe-js/bobe#readme",
  "description": "bobe's url router"
}
