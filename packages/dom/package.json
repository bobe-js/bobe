{
  "name": "bobe-dom",
  "version": "0.0.77",
  "type": "module",
  "main": "dist/bobe-dom.cjs",
  "module": "dist/bobe-dom.esm.js",
  "browser": "dist/bobe-dom.umd.js",
  "types": "dist/index.d.ts",
  "private": false,
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "@iconify/utils": "^3.1.3",
    "bobe": "workspace:*",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "htmlparser2": "^12.0.0",
    "iconify-icon": "^3.0.2",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bobe-dom.esm.js",
      "require": "./dist/bobe-dom.cjs"
    },
    "./plugin-markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.esm.js",
      "require": "./dist/markdown.cjs"
    },
    "./plugin-iconify": {
      "types": "./dist/iconify.d.ts",
      "import": "./dist/iconify.esm.js",
      "require": "./dist/iconify.cjs"
    },
    "./plugin-markdown/code": {
      "types": "./dist/code.d.ts",
      "import": "./dist/code.esm.js",
      "require": "./dist/code.cjs"
    },
    "./plugin-markdown/index.css": "./dist/index.css",
    "./plugin-markdown/code.css": "./dist/code.css",
    "./ssr": {
      "import": "./dist/ssr-index.esm.js",
      "require": "./dist/ssr-index.cjs"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && rollup -c",
    "dev": "rollup -c -w",
    "tw": "vitest"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "keywords": [
    "bobe-dom",
    "smooth",
    "cat"
  ],
  "author": "smooth-cat",
  "repository": {
    "type": "git",
    "url": "git+git@github.com:bobe-js/bobe.git"
  },
  "bugs": {
    "url": "https://github.com/bobe-js/bobe/issues"
  },
  "homepage": "https://github.com/bobe-js/bobe#readme",
  "description": "Bobe customize render for DOM"
}
